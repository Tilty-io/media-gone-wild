{
  "name": "tilty/media-gone-wild",
  "description": "API de médias aléatoires (photos, logos, vidéos)",
  "type": "project",
  "require": {
    "php": "^8.4",
    "codeigniter4/framework": "^4.7",
    "ext-fileinfo": "*",
    "intervention/image": "^4.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Config\\": "app/Config/",
      "MediaGoneWild\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MediaGoneWild\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}

